{
  "manifest_version": 3,
  "name": "TL;DW — YouTube summarizer",
  "version": "0.1.0",
  "description": "Summarize the current YouTube video into a text TL;DW via your local tldw server.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": ["http://127.0.0.1:8765/*"],
  "background": { "scripts": ["background.js"] },
  "browser_specific_settings": {
    "gecko": { "id": "tldw@drewcurley", "strict_min_version": "115.0" }
  },
  "action": {
    "default_title": "TL;DW this video",
    "default_icon": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
  },
  "options_ui": { "page": "options.html", "open_in_tab": true },
  "icons": { "16": "icons/icon16.png", "48": "icons/icon48.png", "128": "icons/icon128.png" }
}
